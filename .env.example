# Server configuration
SERVER_PORT=5000
SERVER_HOST=0.0.0.0
APP_ENV=development

# Database configuration
DATABASE_URL=postgresql://postgres:password@localhost:5432/guard_firearm_system

# Email configuration
GMAIL_USER=your_gmail@gmail.com
GMAIL_PASSWORD=your_app_password

# Admin configuration
ADMIN_CODE=122601

# JWT configuration (optional, for token-based auth)
JWT_SECRET=your_secret_key_here
JWT_EXPIRATION_HOURS=24

# Production hardening (required when APP_ENV=production)
# - JWT_SECRET must be a strong secret (32+ chars)
# - ADMIN_CODE must not be the default 122601
# - CORS_ORIGINS or CORS_ORIGIN must be configured

# CORS configuration (production)
# Comma-separated origins, for example:
# CORS_ORIGINS=https://dasiasentinel.xyz,https://www.dasiasentinel.xyz,capacitor://localhost,tauri://localhost,https://localhost
# Or single origin fallback:
# CORS_ORIGIN=https://dasiasentinel.xyz
