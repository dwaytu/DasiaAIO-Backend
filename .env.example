# Server configuration
SERVER_PORT=5000
SERVER_HOST=0.0.0.0
APP_ENV=development

# Database configuration
DATABASE_URL=postgresql://postgres:password@localhost:5432/guard_firearm_system

# Email configuration
GMAIL_USER=your_gmail@gmail.com
GMAIL_PASSWORD=your_app_password

# Admin configuration
ADMIN_CODE=122601

# JWT configuration (optional, for token-based auth)
JWT_SECRET=your_secret_key_here
JWT_EXPIRY_HOURS=24
JWT_REFRESH_EXPIRY_HOURS=168
PASSWORD_RESET_CODE_LENGTH=8

# API security controls
REQUEST_TIMEOUT_SECS=30
AUTH_RATE_LIMIT_MAX=10
AUTH_RATE_LIMIT_WINDOW_SECS=60
API_RATE_LIMIT_MAX=240
API_RATE_LIMIT_WINDOW_SECS=60
EXPENSIVE_RATE_LIMIT_MAX=30
EXPENSIVE_RATE_LIMIT_WINDOW_SECS=60
SECURITY_CSP=default-src 'none'; frame-ancestors 'none'; base-uri 'none'; form-action 'none'; object-src 'none'

# System version endpoint metadata
APP_VERSION=v1.0.0
APP_CHANGELOG=Platform stability and security hardening improvements.
WEB_DOWNLOAD_URL=https://github.com/Cloudyrowdyyy/Capstone-Main/releases/latest
DESKTOP_DOWNLOAD_URL=https://github.com/Cloudyrowdyyy/Capstone-Main/releases/latest
MOBILE_DOWNLOAD_URL=https://github.com/Cloudyrowdyyy/Capstone-Main/releases/latest

# Production hardening (required when APP_ENV=production)
# - JWT_SECRET must be a strong secret (32+ chars)
# - ADMIN_CODE must not be the default 122601
# - CORS_ORIGINS or CORS_ORIGIN must be configured

# CORS configuration (production)
# Comma-separated origins, for example:
# CORS_ORIGINS=https://dasiasentinel.xyz,https://www.dasiasentinel.xyz,capacitor://localhost,tauri://localhost,https://localhost
# Or single origin fallback:
# CORS_ORIGIN=https://dasiasentinel.xyz
